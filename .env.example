# Channelarr — Environment Variables
# Copy to .env and fill in values.

# ── VPN (Mullvad/Gluetun) ──
VPN_PROVIDER=mullvad
VPN_TYPE=wireguard
WG_PRIVATE_KEY=
WG_ADDRESSES=10.70.17.30/32
VPN_CITIES=Atlanta GA,Raleigh NC,Ashburn VA

# Gluetun control server auth (used by both gluetun and channelarr)
VPN_CONTROL_USER=admin
VPN_CONTROL_PASS=

# ── Database ──
PG_HOST=192.168.20.15
PG_PORT=5432
PG_USER=channelarr
PG_PASS=
PG_DB=channelarr

# ── App ──
BASE_URL=http://192.168.20.34:5045

# ── Logging ──
SYSLOG_ADDRESS=tcp://localhost:1514
