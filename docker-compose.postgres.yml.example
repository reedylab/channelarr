services:
  postgres:
    image: postgres:16
    container_name: channelarr-db
    environment:
      POSTGRES_DB: ${PG_DB:-channelarr}
      POSTGRES_USER: ${PG_USER:-channelarr}
      POSTGRES_PASSWORD: ${PG_PASS:?Set PG_PASS in .env}
    volumes:
      - pgdata:/var/lib/postgresql/data
    networks:
      - internal
    restart: unless-stopped

  # Selenium undetected-chromedriver sidecar.
  # Not behind gluetun in this example — if your host already runs another
  # gluetun (e.g. for manifold) using the same Mullvad key, a second one on
  # the same host will fail to handshake. Add gluetun back here once you have
  # a separate Mullvad device/key.
  selenium-uc:
    build: ./selenium-uc
    container_name: channelarr-selenium-uc
    shm_size: 2g
    ports:
      - "4445:4445"
    volumes:
      - selenium_profile:/data
    networks:
      - internal
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: "${SYSLOG_ADDRESS:-tcp://localhost:1514}"
        tag: "channelarr-selenium-uc"

  channelarr:
    build: .
    container_name: channelarr
    env_file: .env
    environment:
      - PYTHONUNBUFFERED=1
      - BASE_URL=${BASE_URL:-http://your-server-ip:5045}
      - PG_HOST=channelarr-db
      - PG_PORT=5432
      - PG_USER=${PG_USER:-channelarr}
      - PG_PASS=${PG_PASS}
      - PG_DB=${PG_DB:-channelarr}
      - SELENIUM_URL=http://channelarr-selenium-uc:4445
    ports:
      - "5045:5045"
    volumes:
      - /path/to/media:/media:ro
      - /path/to/bumps:/bumps
      - /path/to/m3u:/m3u
      - channelarr-data:/app/data
      - channelarr-logs:/app/logs
      - /path/to/youtube-cache:/yt_cache
    depends_on:
      - postgres
      - selenium-uc
    networks:
      - internal
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        syslog-address: "${SYSLOG_ADDRESS:-tcp://localhost:1514}"
        tag: "channelarr"

networks:
  internal:

volumes:
  channelarr-data:
  channelarr-logs:
  pgdata:
  selenium_profile:
    external: true
    name: channelarr_selenium_profile
